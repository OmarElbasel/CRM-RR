# Clerk authentication keys
# Get these from your Clerk dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_with_your_key
CLERK_SECRET_KEY=sk_test_replace_with_your_key

# Backend API URL
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Feature flags (must be prefixed NEXT_PUBLIC_ to be available in browser)
NEXT_PUBLIC_FLAG_AI_GENERATION=false
NEXT_PUBLIC_FLAG_BILLING=false
NEXT_PUBLIC_FLAG_SALLA_INTEGRATION=false
NEXT_PUBLIC_FLAG_ZID_INTEGRATION=false
NEXT_PUBLIC_FLAG_UI_REDESIGN=false
NEXT_PUBLIC_FLAG_PLUGIN_EMBED=false
NEXT_PUBLIC_FLAG_PIPELINE=false
NEXT_PUBLIC_FLAG_SHOPIFY_ORDER_HUB=false

# Phase 10 — TikTok Inbox + AI Content Assistant
NEXT_PUBLIC_FLAG_TIKTOK_INBOX=false
NEXT_PUBLIC_FLAG_CONTENT_ASSISTANT=false
NEXT_PUBLIC_FLAG_POST_SCHEDULER=false

# Phase 10 — Observability
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
 
# Developer Admin Panel (Server-side only — no NEXT_PUBLIC_ prefix)
ADMIN_CLERK_USER_IDS=user_replace_with_your_clerk_id
