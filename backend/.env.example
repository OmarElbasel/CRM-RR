# Django settings
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=django-insecure-replace-this-in-production

# Database (Railway provides this automatically in production)
DATABASE_URL=postgres://user:password@localhost:5432/rawaj_dev

# Clerk JWT settings
# Get these from your Clerk dashboard → API Keys → Advanced
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/v1/jwks
CLERK_ISSUER=https://your-clerk-domain.clerk.accounts.dev

# Allowed hosts (comma-separated, production only)
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS (comma-separated list of allowed frontend origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Superuser (used by create_superuser_from_env management command)
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me-in-development

# Feature flags (all default to false — off until explicitly enabled)
FLAG_AI_GENERATION=false
FLAG_BILLING=false

# Redis (used for caching and Celery broker)
REDIS_URL=redis://localhost:6379/0

# Stripe (Phase 4 — Billing)
STRIPE_SECRET_KEY=sk_test_replace_with_your_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_key
STRIPE_PRICE_STARTER=price_replace_with_starter_price_id
STRIPE_PRICE_PRO=price_replace_with_pro_price_id

# Fernet key for API secret key encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-generated-fernet-key

# Frontend URL (for Stripe Checkout redirect URLs)
FRONTEND_URL=http://localhost:3000
FLAG_SALLA_INTEGRATION=false
FLAG_ZID_INTEGRATION=false

# Meta / Facebook App (Phase 5 — Unified Social Inbox)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_WEBHOOK_VERIFY_TOKEN=choose_a_random_string_here
FLAG_INBOX_ENABLED=false
FLAG_PIPELINE_ENABLED=false

# Phase 7 — Shopify Order Hub
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_API_VERSION=2024-01
BACKEND_BASE_URL=https://api.rawaj.io
FRONTEND_URL=https://app.rawaj.io
FLAG_SHOPIFY_ORDER_HUB=false

# Phase 10 — TikTok Inbox + AI Content Assistant
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret
FLAG_TIKTOK_INBOX=false
FLAG_CONTENT_ASSISTANT=false
FLAG_POST_SCHEDULER=false
